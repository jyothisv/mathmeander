# Copy to .env (done by `just bootstrap`). Every variable the system reads, with working
# dev defaults for non-secrets. NOTHING in this file is a real secret; real deployments
# use platform secret stores against the same names.

# ── Postgres (docker-compose; PG18 — minimum supported is PG15 for NULLS NOT DISTINCT) ──
POSTGRES_PORT=5432
DATABASE_URL=postgres://mathmeander:mathmeander@localhost:5432/mathmeander_dev?sslmode=disable
TEST_DATABASE_URL=postgres://mathmeander:mathmeander@localhost:5432/mathmeander_test?sslmode=disable

# ── Object storage (MinIO in dev — S3-compatible stand-in for Cloudflare R2). ──
# Well-known MinIO dev defaults; no client code consumes these until slice 3 (sources).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=mathmeander-dev-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Server (glue tier) ──
SERVER_PORT=8787
WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ── Auth seam (arch doc §7: hosted-IdP-shaped; dev-idp in development) ──
# Swapping in Clerk/WorkOS/Auth.js later = changing these values only.
DEV_IDP_PORT=8788
AUTH_ISSUER=http://localhost:8788
AUTH_JWKS_URL=http://localhost:8788/jwks.json
AUTH_AUDIENCE=mathmeander-api
